  "keyFeatures": [
    "JWT-based authentication and authorization",
    "Complete CRUD operations for incidents, users, categories, and comments",
    "ML-based incident priority classification using TF-IDF",
    "DBSCAN clustering for critical zone detection",
    "Geolocation support with latitude/longitude coordinates",
    "Test data generation endpoints"
  ],
  "publicApiSurface": [
    "POST /register - User registration",
    "POST /login - User authentication",
    "GET /incidentes/ - List incidents",
    "POST /incidente/ - Create incident",
    "GET /incidentes_prioridad - Get incidents with ML priority",
    "GET /ml/zonas-criticas - Detect critical zones using DBSCAN",
    "GET /usuarios/ - List users (authenticated)",
    "GET /categorias/ - List categories",
    "GET /comentarios/ - List comments",
    "POST /generar-datos/ - Generate test data"
  ]
}
